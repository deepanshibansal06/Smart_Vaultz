# API base URL (no trailing slash). Must be reachable from the device running the app.
# - Desktop / same machine: http://localhost:5000/api
# - Android emulator: use host machine as 10.0.2.2 → http://10.0.2.2:5000/api
# - Physical device or installed APK: use your server's URL (e.g. https://your-backend.onrender.com/api
#   or http://YOUR_PC_IP:5000/api). Ensure .env exists before 'flutter build apk' so the APK bundles it.
BASE_URL=http://localhost:5000/api
