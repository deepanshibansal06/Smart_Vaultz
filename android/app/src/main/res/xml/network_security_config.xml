<?xml version="1.0" encoding="utf-8"?>
<!-- Allow HTTP (cleartext) so API at http://IP:port works on device. -->
<network-security-config>
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
            <certificates src="user" />
        </trust-anchors>
    </base-config>
</network-security-config>
